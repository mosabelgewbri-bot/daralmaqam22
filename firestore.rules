rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Helpers
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking if the user is the specific admin email
    function isSuperAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             (request.auth.token.email == "mosabelgewbri@gmail.com" || 
              request.auth.token.email.lower() == "mosabelgewbri@gmail.com");
    }

    // General admin check
    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Global Admin Override - Admins can do anything
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Entity Validators (Flexible)
    // ===============================================================

    // Check if fields are correct types IF they are present
    function checkTripFields(data) {
      return (!('name' in data) || (data.name is string && data.name.size() > 0)) &&
             (!('totalSeats' in data) || data.totalSeats is number) &&
             (!('availableSeats' in data) || data.availableSeats is number) &&
             (!('status' in data) || data.status in ['Upcoming', 'Active', 'Completed']);
    }

    // ===============================================================
    // Collection Matches
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if true; // Allow bootstrapping the first admin
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /trips/{tripId} {
      allow read: if true;
      allow create: if isAdmin();
      // Allow update if admin OR if it's a valid seat update
      allow update: if isSignedIn() && (
        isAdmin() || 
        (incoming().diff(existing()).affectedKeys().hasAny(['availableSeats', 'updatedAt']) && checkTripFields(incoming()))
      );
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read, write: if true;
    }

    match /pilgrims/{pilgrimId} {
      allow read, write: if true;
    }

    match /permissions/{permId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read, write: if true;
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /customers/{custId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /umrahOffers/{offerId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /hosted_images/{imageId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /hotels/{hotelId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hotelRooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /umrah_pricing/{priceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Connection test path
    match /test/connection {
      allow read: if true;
    }
  }
}
